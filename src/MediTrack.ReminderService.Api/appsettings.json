{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ReminderDb": "Server=localhost;Port=3306;Database=meditrack_reminder;User=root;Password=root;"
  },
  "Database": {
    "AutoMigrate": true
  },
  "Swagger": {
    "Enabled": true
  },
  "Jwt": {
    "Issuer": "meditrack-gateway",
    "Audience": "meditrack-services",
    "Key": "CHANGE_ME_super_secret_signing_key_min_32_chars_long!"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "meditrack.events",
    "QueueName": "reminder-service.events",
    "OutboxPollingSeconds": 10
  },
  "Scheduler": {
    "PollingSeconds": 15,
    "BatchSize": 100
  },
  "ReminderNotification": {
    "MaxAttempts": 3,
    "BaseDelaySeconds": 2,
    "FcmTopicPrefix": "patient_",
    "EnableLocalFallback": true
  },
  "Fcm": {
    "ProjectId": "",
    "CredentialsPath": "",
    "SimulateDelivery": true
  }
}
